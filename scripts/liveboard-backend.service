[Unit]
Description=LiveBoard Backend
After=network.target postgresql.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/projects/live_board/backend
ExecStart=/home/ubuntu/projects/live_board/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8002 --proxy-headers --forwarded-allow-ips='*'
Restart=always
RestartSec=3
Environment="PATH=/home/ubuntu/.local/bin:/usr/local/bin:/usr/bin:/bin"

[Install]
WantedBy=multi-user.target
